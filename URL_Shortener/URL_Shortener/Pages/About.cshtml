@page
@model URL_Shortener.Pages.AboutModel
@inject IConfiguration Configuration
@{
    var frontendUrl = Configuration.GetValue<string>("FrontendSettings:BaseUrl");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

<div class="min-vh-100 d-flex align-items-center justify-content-center pb-5 bg-light">
    <div class="card shadow-lg rounded-4 border-0 w-100" style="max-width: 600px;">
        <div class="card-body p-5">
            <h2 class="fw-bold text-center mb-4">About Algorithm</h2>

            @if (User.IsInRole("Admin"))
            {
                <form method="post">
                    <input type="hidden" asp-for="AboutContent.Id" />
                    <input type="hidden" asp-for="AboutContent.PageName" />
                    <div class="mb-3">
                        <label class="form-label small text-secondary fw-semibold">
                            Algorithm Description
                        </label>
                        <textarea asp-for="AboutContent.TextContent"
                              class="form-control form-control-lg bg-light border-0"
                              rows="8"
                              required></textarea>
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm fw-bold mt-2 mb-3">
                        Save Changes
                    </button>
                </form>
            }
            else
            {
                <div class="mb-4">
                    <label class="form-label small text-secondary fw-semibold">
                        Algorithm Description
                    </label>
                    <div class="lh-lg text-break">
                        @Model.AboutContent.TextContent
                    </div>
                </div>
            }
            <a href="frontendUrl" class="btn btn-primary btn-lg w-100 shadow-sm fw-bold mt-1">
                Main Page
            </a>
        </div>
    </div>
</div>